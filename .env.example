# Server Environment Variables
PORT=5000
NODE_ENV=development
APP_URL=http://localhost:5173

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=word_of_covenant_db
DB_PORT=3306

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# File Upload
MAX_FILE_SIZE=50MB
UPLOAD_PATH=./uploads

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Email Configuration
EMAIL_HOST=smtp.zoho.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=admin@hocfam.org
EMAIL_PASSWORD=your-app-password
SMTP_TIMEOUT_MS=2500
SMTP_BLOCKING_WAIT_MS=2500
SMTP_FAILURE_COOLDOWN_MS=60000
SMTP_SINGLE_ACCOUNT=true
SMTP_DEBUG=false

# Optional API fallback for mail delivery when SMTP is unreachable
# RESEND_API_KEY=re_xxx
# RESEND_FROM=admin@hocfam.org

# Organization mailbox routing
ORG_EMAIL_ADMIN=admin@hocfam.org
ORG_EMAIL_INFO=info@hocfam.org
ORG_EMAIL_SUPPORT=support@hocfam.org
ORG_EMAIL_MEDIA=media@hocfam.org
PRAYER_REQUEST_EMAIL=admin@hocfam.org

# Option B: per-mailbox SMTP credentials (use app passwords)
EMAIL_ADMIN_USER=admin@hocfam.org
EMAIL_ADMIN_PASSWORD=
EMAIL_INFO_USER=info@hocfam.org
EMAIL_INFO_PASSWORD=
EMAIL_SUPPORT_USER=support@hocfam.org
EMAIL_SUPPORT_PASSWORD=
EMAIL_MEDIA_USER=media@hocfam.org
EMAIL_MEDIA_PASSWORD=

# SMS Configuration (Africa's Talking)
# Get your API key from https://africastalking.com/
SMS_API_KEY=your-africastalking-api-key
SMS_USERNAME=sandbox
SMS_SENDER=WORDCOV

# Alternative: Twilio SMS Configuration
# TWILIO_ACCOUNT_SID=your-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_PHONE_NUMBER=+1234567890
